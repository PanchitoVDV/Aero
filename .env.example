APP_NAME=Aero
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aero
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@cloudito.nl"
MAIL_FROM_NAME="Cloudito"

# VirtFusion Configuration
VIRTFUSION_URL=https://your-virtfusion-instance.com
VIRTFUSION_API_TOKEN=your-virtfusion-api-token
VIRTFUSION_HYPERVISOR_GROUP_ID=1

# Mollie Configuration
MOLLIE_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_URL=https://your-domain.com/webhooks/mollie

# Cloudito Branding
CLOUDITO_COMPANY_NAME=Cloudito
